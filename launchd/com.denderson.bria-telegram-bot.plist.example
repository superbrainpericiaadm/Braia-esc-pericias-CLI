<?xml version="1.0" encoding="UTF-8"?>
<!DOCTYPE plist PUBLIC "-//Apple//DTD PLIST 1.0//EN" "http://www.apple.com/DTDs/PropertyList-1.0.dtd">
<plist version="1.0">
<dict>
    <key>Label</key>
    <string>com.{{DONO_SLUG}}.bria-telegram-bot</string>
    <key>ProgramArguments</key>
    <array>
        <string>/Users/briarodrigues/.pyenv/versions/3.12.8/bin/python3</string>
        <string>/Users/briarodrigues/bria-bot/bot.py</string>
    </array>
    <key>WorkingDirectory</key>
    <string>/Users/briarodrigues/bria-bot</string>
    <key>RunAtLoad</key>
    <true/>
    <key>KeepAlive</key>
    <true/>
    <key>StandardOutPath</key>
    <string>/Users/briarodrigues/bria-bot/logs/launchd-stdout.log</string>
    <key>StandardErrorPath</key>
    <string>/Users/briarodrigues/bria-bot/logs/launchd-stderr.log</string>
    <key>EnvironmentVariables</key>
    <dict>
        <key>PATH</key>
        <string>/opt/homebrew/bin:/opt/homebrew/sbin:/usr/local/bin:/usr/bin:/bin</string>
    </dict>
</dict>
</plist>
